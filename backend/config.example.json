{
  "cluster_mode": "generic",
  "deployment_mode": "ood",
  "execution_mode": "slurm",
  "environment": "production",
  "host": "127.0.0.1",
  "port": 5000,
  "debug": false,
  "relion_bin_path": "/opt/relion/build/bin",
