# RELION Web UI 5 Beta, site configuration
#
# Copy this file to `relion-web-ui.env` and edit the values below to match your
# cluster. Two install variants read this file:
#
#   * scripts/install_relion_beta.sh      → for clusters running Open OnDemand
#   * scripts/install_relion_headless.sh  → for Slurm clusters without OOD
#
# Required keys are marked REQUIRED; everything else has a sensible default.


# ---
# Deployment mode  (only used by the headless installer)
#   headless, nginx + gunicorn + systemd, no Open OnDemand.
#   ood     , Open OnDemand app (used by install_relion_beta.sh).
# The two installers set this internally; you rarely need to override.
# ---
# RELION_DEPLOYMENT_MODE=headless


# ---
# Cluster mode, leave at "generic" for self-hosted installs.
# Only RELION Web UI's own Azure deployment uses "cyclecloud".
# ---
RELION_CLUSTER_MODE=generic


# ---
# OOD cluster id  (REQUIRED for install_relion_beta.sh, not headless)
# This is the filename (without .yml) of your cluster config under
# /etc/ood/config/clusters.d/. For example, if you have
# /etc/ood/config/clusters.d/mycluster.yml, set this to "mycluster".
# The headless install does not need OOD, so this can be left as-is.
# ---
RELION_CLUSTER=slurm


# ---
# Slurm partition  (REQUIRED)
# The partition RELION jobs will be submitted to. Check `sinfo` for options.
# ---
RELION_PARTITION=compute


# ---
# RELION container path  (REQUIRED)
# Absolute path to the RELION 5 Singularity/Apptainer image. We provide a
# pre-built one, see INSTALL.md for the download link.
# ---
RELION_CONTAINER=/opt/relion/relion_backend.sif


# ---
# Default project directory shown to users
# Typically a per-user path under their home directory works well, e.g.
# ${HOME}/relion_projects (the OOD form expands ${HOME} at render time).
# ---
RELION_DEFAULT_PROJECTS_DIR=${HOME}/relion_projects


# ---
# Apptainer / Singularity binary  (default: /usr/bin/apptainer)
# Run `which apptainer || which singularity` to find yours.
# ---
RELION_APPTAINER_BIN=/usr/bin/apptainer


# ---
# Container bind mount(s)  (default: /shared:/shared)
# Comma-separated host:container pairs. Anywhere user data lives must be
# bound, otherwise the container can't read it. Common values:
#   /home:/home,/scratch:/scratch
# ---
RELION_CONTAINER_BIND=/home:/home,/scratch:/scratch


# ---
# Per-job memory request shown in the OOD form  (default: 12G)
# Adjust to match your partition's typical node size.
# ---
RELION_MEM_PER_JOB=12G


# --- Headless-only (install_relion_headless.sh reads these; OOD installer ignores) ---


# Initial basic-auth admin. Password prompted at install if not set here.
# Keep the file 0600 if you set the password.
RELION_HEADLESS_ADMIN_USER=admin
# RELION_HEADLESS_ADMIN_PASSWORD=change-me


# Auth: "passthrough" (nginx basic-auth), "basic" (backend auth), "none".
# RELION_AUTH_MODE=passthrough


# Set to 1 to open port 80 in firewalld during install.
# RELION_OPEN_FIREWALL_HTTP=0


# Install paths (rarely changed)
# RELION_INSTALL_ROOT=/opt/relion-web-ui
# RELION_FRONTEND_DIR=/var/www/relion-web-ui
# RELION_CONDA_ROOT=/opt/miniconda3
# RELION_SVC_USER=relion-web-ui


# --- Local-only (install_relion_local.sh reads these; headless / OOD ignore them) ---


# For the single-machine variant. Set ONE of these to tell us where your
# RELION lives. Native binaries typically live in a directory ending in
# /build/bin (relion_import, relion_refine, etc.).
# RELION_BIN_PATH=/path/to/relion/build/bin
# RELION_CONTAINER=/path/to/relion_backend.sif

# Force local subprocess execution (set by start.sh; you rarely override).
# RELION_EXECUTION_MODE=local


# ---
# Optional, almost nobody needs to touch these.
# ---
# RELION_BACKEND_PORT=5000
# RELION_CTFFIND_BIN=/usr/local/bin/ctffind
# RELION_MPIRUN=mpirun
# RELION_CORS_ORIGINS=*
